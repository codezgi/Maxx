# Maxx Global Medikal — Apache (klasik hosting) performans ayarları
# Not: Vercel/Railway gibi platformlarda bu dosya kullanılmaz; onlar için vercel.json var.

# ---------- UTF-8 ----------
AddDefaultCharset UTF-8

# ---------- GZIP sıkıştırma ----------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml application/xml font/woff2
</IfModule>

# ---------- Tarayıcı önbelleği ----------
<IfModule mod_expires.c>
  ExpiresActive On
  # HTML her zaman güncel kalsın
  ExpiresByType text/html "access plus 0 seconds"
  # Statik varlıklar 1 yıl (dosya değişirse adı değişmese de yeniden yüklenir,
  # bu yüzden büyük tasarım değişikliklerinde dosya adını değiştirmek en garantisidir)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType video/mp4 "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|webp|png|woff2|mp4)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Temel güvenlik başlıkları
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set X-Frame-Options "SAMEORIGIN"
</IfModule>

# ---------- MIME türleri ----------
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType font/woff2 .woff2
  AddType video/mp4 .mp4
</IfModule>

# ---------- www + https yönlendirmesi ----------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} ^maxx-global\.net$ [NC]
  RewriteRule ^(.*)$ https://www.maxx-global.net/$1 [L,R=301]
</IfModule>
